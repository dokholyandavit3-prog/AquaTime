<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="david.dokholyan.aquatime">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AquaTime">

        <!-- Splash запускается первым -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Основное приложение -->
        <activity android:name=".MainActivity" />
        <!-- Экран первого ввода данных -->
        <activity android:name=".UserSetupActivity" />
        <activity android:name=".EditProfileActivity" />
        <receiver
            android:name=".ui.training.TrainingReminderReceiver"
            android:exported="true" />

    </application>
</manifest>
