<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">



        <!-- Карточка статистики за день -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сегодняшняя тренировка"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tv_today_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дистанция: 0 м"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tv_today_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Время: 0:00"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tv_today_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Скорость: 0 м/с"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Кнопка начала тренировки -->
        <Button
            android:id="@+id/btn_start_training"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏁 Начать тренировку"
            android:backgroundTint="@color/aqua_accent"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:layout_marginBottom="20dp" />

        <!-- Блок советов -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:elevation="3dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Совет дня"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_tip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Работай над дыханием и длинной гребка — это повысит твою эффективность."
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Карточка достижений -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:elevation="3dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏅 Твои достижения"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_achievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🥇 Проплыл 100 км!\n🔥 5 дней подряд без пропусков!"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Кнопка истории -->
        <Button
            android:id="@+id/btn_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 История тренировок"
            android:backgroundTint="@color/aqua_primary"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
