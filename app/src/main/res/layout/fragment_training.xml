<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Совет дня -->
        <TextView
            android:id="@+id/tv_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Совет дня"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_tip_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сегодня попробуй работать над техникой."
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <!-- Настроение -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Какое у тебя настроение?"
            android:textSize="18sp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinner_mood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- План тренировки -->
        <TextView
            android:id="@+id/tv_today_training"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сегодняшняя тренировка"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btn_start_training"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Начать тренировку"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btn_training_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="История тренировок"
            android:layout_marginTop="8dp"/>

        <!-- Календарь -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Календарь тренировок"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <CalendarView
            android:id="@+id/calendar_training"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <!-- Прогресс недели -->
        <TextView
            android:id="@+id/tv_week_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Прогресс недели: 0%"
            android:textSize="18sp"
            android:layout_marginTop="10dp"
            android:textStyle="bold"/>

        <!-- Секундомер -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Секундомер"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00:00.000"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btn_start_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Старт"/>

            <Button
                android:id="@+id/btn_stop_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Стоп"
                android:layout_marginStart="10dp"/>

            <Button
                android:id="@+id/btn_reset_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сброс"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- Выбор дистанции -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выбери стиль и дистанцию"
            android:textSize="18sp"
            android:layout_marginTop="20dp"/>

        <Spinner
            android:id="@+id/spinner_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Сохранение результата -->
        <Button
            android:id="@+id/btn_save_measure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сохранить замер"
            android:layout_marginTop="10dp"/>

        <!-- История замеров -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="История замеров"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <ListView
            android:id="@+id/list_results"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:choiceMode="singleChoice"
            android:background="@android:color/white"
            android:layout_marginTop="8dp"/>

        <!-- Удалить выбранный замер -->
        <Button
            android:id="@+id/btn_delete_measure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Удалить выбранный замер"
            android:layout_marginTop="10dp"/>

        <!-- Лучшие результаты -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Лучшие результаты"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <ListView
            android:id="@+id/list_best_results"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@android:color/white"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>