<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AquaTime" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- AquaTime color system -->
        <item name="colorPrimary">@color/aqua_primary</item>
        <item name="colorPrimaryVariant">@color/aqua_secondary</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="colorSecondary">@color/aqua_accent</item>
        <item name="colorSecondaryVariant">@color/aqua_primary</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/background_light</item>

        <!-- Text -->
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
